#!/usr/bin/env bash
# aw-run — render the aw-master-loop template with user-chosen models and
# invoke `archon workflow run` in an isolated worktree.
#
# Usage:
#   scripts/aw-run [options] <EPIC-ID>
#
# Options:
#   --coder    PROVIDER:MODEL           (default: pi:github-copilot/gpt-5.3-codex)
#   --tester   PROVIDER:MODEL           (default: pi:github-copilot/gemini-3-flash-preview)
#   --master   PROVIDER:MODEL           (default: pi:github-copilot/gpt-5.2)
#   --max-impl-iterations N             (default: 10)
#   --max-fix-attempts   N              (default: 3)
#   --max-arbitration-attempts N        (default: 3; on Nth unsure, hard-fail)
#   --branch BRANCH                     (default: archon/epic-<EPIC-ID>)
#   --from-branch BRANCH                (default: repo default branch / main)
#   --no-autocommit                     skip the in-workflow commit node
#   --keep-worktree                     do not run `archon complete` on success
#   --dry-run                           render YAML and print path; do not run
#
# Phase-skip flags (save tokens when a phase was already done):
#   --skip-implement   skip the implement node (auto-set if epic is review/complete)
#   --skip-write-tests skip the write-tests node (auto-set if test files exist)
#   --tests-only       shorthand: --skip-implement
#                        (write tests if needed, then run them)
#   --reuse-tests      shorthand: --skip-implement --skip-write-tests
#                        (run existing tests on existing code, no AI writes)
#
# Auto-detection (no flags needed):
#   - epic status == review or complete  → skip implement automatically
#   - status == review AND test files exist in worktree → also skip write-tests
#
# PROVIDER must be one of: pi, claude, codex.
# For pi, MODEL must be <catalog-provider>/<model-id>, e.g.:
#   pi:github-copilot/gpt-5.3-codex
#   pi:openai/gpt-4o
#   pi:google/gemini-2.5-pro
#   pi:openrouter/qwen/qwen3-coder  (nested slash OK)
#
# Autocommit and worktree cleanup are ON by default.

set -euo pipefail

# Model defaults — chosen for throughput, not just capability.
# claude-sonnet-4.6 is the most capable but throttles severely under
# sequential load (GitHub Copilot tier). Codex models have higher code
# throughput; gemini-3-flash is the fastest for simpler tasks.
#
# Override any role per-run:  scripts/aw-run --coder pi:github-copilot/claude-sonnet-4.6 EPIC
DEFAULT_CODER="pi:github-copilot/gpt-5.3-codex"   # code-optimised, 400K ctx, high throughput
DEFAULT_TESTER="pi:github-copilot/gemini-3-flash-preview"  # fast, sufficient for test writing
DEFAULT_MASTER="pi:github-copilot/gpt-5.2"         # strong reasoning for arbitration
CODER="$DEFAULT_CODER"
TESTER="$DEFAULT_TESTER"
MASTER="$DEFAULT_MASTER"
FROM_BRANCH=""
SKIP_IMPLEMENT=false
SKIP_WRITE_TESTS=false
MAX_IMPL=10
MAX_FIX=3
MAX_ARB=3
BRANCH=""
DRY=0
AUTOCOMMIT=1
CLEAN_WORKTREE=1

usage() { sed -n '2,28p' "$0"; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        --coder)               CODER="$2"; shift 2 ;;
        --tester)              TESTER="$2"; shift 2 ;;
        --master)              MASTER="$2"; shift 2 ;;
        --max-impl-iterations) MAX_IMPL="$2"; shift 2 ;;
        --max-fix-attempts)    MAX_FIX="$2"; shift 2 ;;
        --max-arbitration-attempts) MAX_ARB="$2"; shift 2 ;;
        --branch)              BRANCH="$2"; shift 2 ;;
        --from-branch)         FROM_BRANCH="$2"; shift 2 ;;
        --skip-implement)      SKIP_IMPLEMENT=true; shift ;;
        --skip-write-tests)    SKIP_WRITE_TESTS=true; shift ;;
        --tests-only)          SKIP_IMPLEMENT=true; shift ;;         # write tests if needed, then run
        --reuse-tests)         SKIP_IMPLEMENT=true; SKIP_WRITE_TESTS=true; shift ;; # run existing tests
        --no-autocommit)       AUTOCOMMIT=0; shift ;;
        --keep-worktree)       CLEAN_WORKTREE=0; shift ;;
        --dry-run)             DRY=1; shift ;;
        -h|--help)             usage; exit 0 ;;
        --) shift; break ;;
        -*) echo "unknown flag: $1" >&2; usage >&2; exit 2 ;;
        *)  EPIC="$1"; shift ;;
    esac
done

: "${EPIC:?EPIC-ID is required}"
BRANCH="${BRANCH:-archon/epic-${EPIC}}"

# Split PROVIDER:MODEL — for pi, MODEL may contain slashes (e.g. github-copilot/claude-sonnet-4.6).
split() { local prov mdl; prov="${1%%:*}"; mdl="${1#*:}"; echo "$prov" "$mdl"; }
read -r CODER_PROV  CODER_MDL  < <(split "$CODER")
read -r TESTER_PROV TESTER_MDL < <(split "$TESTER")
read -r MASTER_PROV MASTER_MDL < <(split "$MASTER")

# Validate Pi model refs: must contain a '/' (catalog-provider/model-id).
check_pi_model() {
    local role="$1" prov="$2" mdl="$3"
    if [[ "$prov" == "pi" && "$mdl" != */* ]]; then
        echo "error: $role model '$mdl' is not a valid Pi model ref." >&2
        echo "  Pi requires format: <catalog-provider>/<model-id>" >&2
        echo "  Examples: github-copilot/claude-sonnet-4.6  openai/gpt-4o  google/gemini-2.5-pro" >&2
        exit 2
    fi
}
check_pi_model "--coder"  "$CODER_PROV"  "$CODER_MDL"
check_pi_model "--tester" "$TESTER_PROV" "$TESTER_MDL"
check_pi_model "--master" "$MASTER_PROV" "$MASTER_MDL"

REPO_ROOT="$(git rev-parse --show-toplevel)"
TEMPLATE="$REPO_ROOT/.archon/workflows/aw-master-loop.template.yaml.tmpl"
RUNS_DIR="$REPO_ROOT/.archon/workflows/.runs"
mkdir -p "$RUNS_DIR"
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-${EPIC//[^A-Za-z0-9]/_}"
WF_NAME="aw-master-loop-$RUN_ID"
OUT="$RUNS_DIR/$WF_NAME.yaml"

sed \
    -e "s|{{RUN_ID}}|$RUN_ID|g" \
    -e "s|{{MASTER_PROVIDER}}|$MASTER_PROV|g" \
    -e "s|{{MASTER_MODEL}}|$MASTER_MDL|g" \
    -e "s|{{CODER_PROVIDER}}|$CODER_PROV|g" \
    -e "s|{{CODER_MODEL}}|$CODER_MDL|g" \
    -e "s|{{TESTER_PROVIDER}}|$TESTER_PROV|g" \
    -e "s|{{TESTER_MODEL}}|$TESTER_MDL|g" \
    -e "s|{{MAX_IMPL_ITERATIONS}}|$MAX_IMPL|g" \
    -e "s|{{MAX_FIX_ATTEMPTS}}|$MAX_FIX|g" \
    -e "s|{{SKIP_IMPLEMENT}}|$SKIP_IMPLEMENT|g" \
    -e "s|{{SKIP_WRITE_TESTS}}|$SKIP_WRITE_TESTS|g" \
    -e "s|{{CONFIGURE_FLAGS}}|$([ "$SKIP_IMPLEMENT" = true ] && printf '%s' '--skip-implement '; [ "$SKIP_WRITE_TESTS" = true ] && printf '%s' '--skip-write-tests')|g" \
    "$TEMPLATE" > "$OUT"

if [[ "$AUTOCOMMIT" -eq 0 ]]; then
    # strip the commit node block between the AUTOCOMMIT markers
    sed -i '/>>> AUTOCOMMIT/,/<<< AUTOCOMMIT/d' "$OUT"
fi

echo "rendered → $OUT"
echo "  coder       = $CODER_PROV / $CODER_MDL"
echo "  tester      = $TESTER_PROV / $TESTER_MDL"
echo "  master      = $MASTER_PROV / $MASTER_MDL"
echo "  branch      = $BRANCH"
echo "  max-fix     = $MAX_FIX"
echo "  max-arb     = $MAX_ARB"
echo "  autocommit  = $AUTOCOMMIT"
echo "  cleanup     = $CLEAN_WORKTREE"
[[ "$SKIP_IMPLEMENT" == "true" ]]   && echo "  skip-impl   = yes (will be refined by configure node)"
[[ "$SKIP_WRITE_TESTS" == "true" ]] && echo "  skip-tests  = yes (will be refined by configure node)"

if [[ "$DRY" -eq 1 ]]; then
    exit 0
fi

archon validate workflows "$WF_NAME"

mkdir -p "$REPO_ROOT/.archon/state"
export MAX_ARBITRATION_ATTEMPTS="$MAX_ARB"
MARKER="$REPO_ROOT/.archon/state/iterate-decision-${EPIC//[^A-Za-z0-9]/_}"
rm -f "$MARKER"

# ── Loop: each iteration is one Archon DAG run. The workflow's final
# `decide` node writes CONVERGED / EXHAUSTED / ITERATE / FAILED to MARKER;
# we read it after each run and loop or break accordingly.
ITER=0
RC=0
while : ; do
    ITER=$((ITER+1))
    if [[ "$ITER" -eq 1 ]]; then
        WT_FLAG=(--branch "$BRANCH")
        [[ -n "$FROM_BRANCH" ]] && WT_FLAG+=(--from-branch "$FROM_BRANCH")
    else
        WT_FLAG=(--no-worktree)
    fi
    echo "=== aw-run iteration $ITER ==="
    set +e
    archon workflow run "$WF_NAME" "$EPIC" "${WT_FLAG[@]}" 2>&1 | tee /tmp/aw-run-archon-$$.log
    RC=${PIPESTATUS[0]}
    set -e
    STATE="$(cat "$MARKER" 2>/dev/null || echo UNKNOWN)"
    # Fallback: if archon reported success but decide's marker didn't reach us
    # (e.g. marker written to worktree before the aw-decide.sh fix), trust archon.
    if [[ "$STATE" == "UNKNOWN" && "$RC" -eq 0 ]] && \
       grep -q "Workflow completed successfully" /tmp/aw-run-archon-$$.log 2>/dev/null; then
        STATE="CONVERGED"
        echo "  (fallback: archon reported success — treating as CONVERGED)"
    fi
    rm -f /tmp/aw-run-archon-$$.log
    echo "  iteration $ITER finished: rc=$RC state=$STATE"
    case "$STATE" in
        CONVERGED) RC=0; break ;;
        EXHAUSTED) RC=42; break ;;   # BLOCKED-ARBITRATION-EXHAUSTED
        ITERATE)   continue ;;
        *)         break ;;          # FAILED / UNKNOWN -> exit with archon's RC
    esac
done

# ── Rate-limit diagnostic helper ───────────────────────────────────────────
# Reads the Archon run log and aw-run-all log (if present) for
# claude.rate_limit_event JSON entries, then prints a human-readable summary.
print_rate_limit_info() {
  local log_sources=()
  # aw-run-all saves per-epic logs here
  [[ -f "$REPO_ROOT/.archon/run-all-logs/${EPIC}.log" ]] && \
    log_sources+=("$REPO_ROOT/.archon/run-all-logs/${EPIC}.log")
  # Archon writes per-run JSONL logs here; find the most recent one
  local archon_log
  archon_log="$(find ~/.archon/workspaces -name '*.jsonl' -not -path '*/sessions/*' \
    -newer "$REPO_ROOT/.archon/state" 2>/dev/null | sort -t/ -k1 | tail -1)"
  [[ -n "$archon_log" ]] && log_sources+=("$archon_log")

  if [[ ${#log_sources[@]} -eq 0 ]]; then return; fi

  python3 - "${log_sources[@]}" <<'PYEOF'
import sys, json, time
from datetime import datetime

events = []
for path in sys.argv[1:]:
    try:
        for line in open(path):
            line = line.strip()
            if not line: continue
            try:
                obj = json.loads(line)
                if obj.get('msg') == 'claude.rate_limit_event':
                    events.append(obj)
            except Exception:
                pass
    except OSError:
        pass

if not events:
    sys.exit(0)

print()
print('=' * 60)
print('  ⛔  RATE LIMIT DETECTED IN THIS RUN')
print('=' * 60)
seen = set()
for e in events:
    info = e.get('rateLimitInfo', {})
    key = (info.get('rateLimitType'), info.get('overageDisabledReason'))
    if key in seen: continue
    seen.add(key)
    limit_type = info.get('rateLimitType', 'unknown')
    reason     = info.get('overageDisabledReason', '')
    reset_ts   = info.get('resetsAt')
    overage    = info.get('overageStatus', '')

    desc_map = {
        'five_hour': '5-hour rolling window',
        'daily':     'daily token quota',
        'weekly':    'weekly token quota',
        'monthly':   'monthly token quota',
    }
    print(f'  Limit type : {desc_map.get(limit_type, limit_type)}')
    if reason:    print(f'  Reason     : {reason}')
    if overage:   print(f'  Overage    : {overage}')
    if reset_ts:
        dt   = datetime.fromtimestamp(reset_ts)
        mins = max(0, int((reset_ts - time.time()) / 60))
        wait = f'{mins} min' if mins < 120 else f'{mins//60}h {mins%60}min'
        print(f'  Resets at  : {dt.strftime("%Y-%m-%d %H:%M:%S")} (in {wait})')
print()
print('  \U0001f4a1 Suggestions:')
print('     Wait for the reset, then re-run:')
print('       scripts/aw-run [--from EPIC-ID]')
print()
print('     Or switch to a non-throttled model now:')
print('       scripts/aw-run --coder pi:github-copilot/gpt-5.3-codex  (current default)')
print('       scripts/aw-run --coder pi:github-copilot/gemini-3-flash-preview')
print('       scripts/aw-run --coder pi:github-copilot/gpt-5.2')
print('=' * 60)
PYEOF
}

if [[ "$RC" -eq 0 && "$CLEAN_WORKTREE" -eq 1 ]]; then
    archon complete "$BRANCH" || echo "warning: 'archon complete' failed; clean up manually" >&2
elif [[ "$RC" -eq 42 ]]; then
    echo "BLOCKED-ARBITRATION-EXHAUSTED after $ITER iteration(s) — worktree $BRANCH preserved for human review" >&2
else
    echo "workflow failed (rc=$RC) after $ITER iteration(s) — worktree $BRANCH preserved" >&2
    print_rate_limit_info
fi

exit "$RC"
