#!/usr/bin/env bash
# aw-run — render the aw-master-loop template with user-chosen models and
# invoke `archon workflow run` in an isolated worktree.
#
# Usage:
#   scripts/aw-run [options] <EPIC-ID>
#
# Options:
#   --coder    PROVIDER:MODEL           (default: pi:github-copilot/claude-sonnet-4.6)
#   --tester   PROVIDER:MODEL           (default: pi:github-copilot/claude-sonnet-4.6)
#   --master   PROVIDER:MODEL           (default: pi:github-copilot/claude-sonnet-4.6)
#   --max-impl-iterations N             (default: 10)
#   --max-fix-attempts   N              (default: 3)
#   --max-arbitration-attempts N        (default: 3; on Nth unsure, hard-fail)
#   --branch BRANCH                     (default: archon/epic-<EPIC-ID>)
#   --from-branch BRANCH                (default: repo default branch / main)
#   --no-autocommit                     skip the in-workflow commit node
#   --keep-worktree                     do not run `archon complete` on success
#   --dry-run                           render YAML and print path; do not run
#
# PROVIDER must be one of: pi, claude, codex.
# For pi, MODEL must be <catalog-provider>/<model-id>, e.g.:
#   pi:github-copilot/claude-sonnet-4.6
#   pi:openai/gpt-4o
#   pi:google/gemini-2.5-pro
#   pi:openrouter/qwen/qwen3-coder  (nested slash OK)
#
# Defaults: all three roles use the Pi provider with your configured default
# (github-copilot/claude-sonnet-4.6). Override per-run with the flags above.
# Autocommit and worktree cleanup are ON by default.

set -euo pipefail

DEFAULT_PI_MODEL="pi:github-copilot/claude-sonnet-4.6"
CODER="$DEFAULT_PI_MODEL"
TESTER="$DEFAULT_PI_MODEL"
MASTER="$DEFAULT_PI_MODEL"
FROM_BRANCH=""
MAX_IMPL=10
MAX_FIX=3
MAX_ARB=3
BRANCH=""
DRY=0
AUTOCOMMIT=1
CLEAN_WORKTREE=1

usage() { sed -n '2,28p' "$0"; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        --coder)               CODER="$2"; shift 2 ;;
        --tester)              TESTER="$2"; shift 2 ;;
        --master)              MASTER="$2"; shift 2 ;;
        --max-impl-iterations) MAX_IMPL="$2"; shift 2 ;;
        --max-fix-attempts)    MAX_FIX="$2"; shift 2 ;;
        --max-arbitration-attempts) MAX_ARB="$2"; shift 2 ;;
        --branch)              BRANCH="$2"; shift 2 ;;
        --from-branch)         FROM_BRANCH="$2"; shift 2 ;;
        --no-autocommit)       AUTOCOMMIT=0; shift ;;
        --keep-worktree)       CLEAN_WORKTREE=0; shift ;;
        --dry-run)             DRY=1; shift ;;
        -h|--help)             usage; exit 0 ;;
        --) shift; break ;;
        -*) echo "unknown flag: $1" >&2; usage >&2; exit 2 ;;
        *)  EPIC="$1"; shift ;;
    esac
done

: "${EPIC:?EPIC-ID is required}"
BRANCH="${BRANCH:-archon/epic-${EPIC}}"

# Split PROVIDER:MODEL — for pi, MODEL may contain slashes (e.g. github-copilot/claude-sonnet-4.6).
split() { local prov mdl; prov="${1%%:*}"; mdl="${1#*:}"; echo "$prov" "$mdl"; }
read -r CODER_PROV  CODER_MDL  < <(split "$CODER")
read -r TESTER_PROV TESTER_MDL < <(split "$TESTER")
read -r MASTER_PROV MASTER_MDL < <(split "$MASTER")

# Validate Pi model refs: must contain a '/' (catalog-provider/model-id).
check_pi_model() {
    local role="$1" prov="$2" mdl="$3"
    if [[ "$prov" == "pi" && "$mdl" != */* ]]; then
        echo "error: $role model '$mdl' is not a valid Pi model ref." >&2
        echo "  Pi requires format: <catalog-provider>/<model-id>" >&2
        echo "  Examples: github-copilot/claude-sonnet-4.6  openai/gpt-4o  google/gemini-2.5-pro" >&2
        exit 2
    fi
}
check_pi_model "--coder"  "$CODER_PROV"  "$CODER_MDL"
check_pi_model "--tester" "$TESTER_PROV" "$TESTER_MDL"
check_pi_model "--master" "$MASTER_PROV" "$MASTER_MDL"

REPO_ROOT="$(git rev-parse --show-toplevel)"
TEMPLATE="$REPO_ROOT/.archon/workflows/aw-master-loop.template.yaml.tmpl"
RUNS_DIR="$REPO_ROOT/.archon/workflows/.runs"
mkdir -p "$RUNS_DIR"
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-${EPIC//[^A-Za-z0-9]/_}"
WF_NAME="aw-master-loop-$RUN_ID"
OUT="$RUNS_DIR/$WF_NAME.yaml"

sed \
    -e "s|{{RUN_ID}}|$RUN_ID|g" \
    -e "s|{{MASTER_PROVIDER}}|$MASTER_PROV|g" \
    -e "s|{{MASTER_MODEL}}|$MASTER_MDL|g" \
    -e "s|{{CODER_PROVIDER}}|$CODER_PROV|g" \
    -e "s|{{CODER_MODEL}}|$CODER_MDL|g" \
    -e "s|{{TESTER_PROVIDER}}|$TESTER_PROV|g" \
    -e "s|{{TESTER_MODEL}}|$TESTER_MDL|g" \
    -e "s|{{MAX_IMPL_ITERATIONS}}|$MAX_IMPL|g" \
    -e "s|{{MAX_FIX_ATTEMPTS}}|$MAX_FIX|g" \
    "$TEMPLATE" > "$OUT"

if [[ "$AUTOCOMMIT" -eq 0 ]]; then
    # strip the commit node block between the AUTOCOMMIT markers
    sed -i '/>>> AUTOCOMMIT/,/<<< AUTOCOMMIT/d' "$OUT"
fi

echo "rendered → $OUT"
echo "  coder       = $CODER_PROV / $CODER_MDL"
echo "  tester      = $TESTER_PROV / $TESTER_MDL"
echo "  master      = $MASTER_PROV / $MASTER_MDL"
echo "  branch      = $BRANCH"
echo "  max-fix     = $MAX_FIX"
echo "  max-arb     = $MAX_ARB"
echo "  autocommit  = $AUTOCOMMIT"
echo "  cleanup     = $CLEAN_WORKTREE"

if [[ "$DRY" -eq 1 ]]; then
    exit 0
fi

archon validate workflows "$WF_NAME"

mkdir -p "$REPO_ROOT/.archon/state"
export MAX_ARBITRATION_ATTEMPTS="$MAX_ARB"
MARKER="$REPO_ROOT/.archon/state/iterate-decision-${EPIC//[^A-Za-z0-9]/_}"
rm -f "$MARKER"

# ── Loop: each iteration is one Archon DAG run. The workflow's final
# `decide` node writes CONVERGED / EXHAUSTED / ITERATE / FAILED to MARKER;
# we read it after each run and loop or break accordingly.
ITER=0
RC=0
while : ; do
    ITER=$((ITER+1))
    if [[ "$ITER" -eq 1 ]]; then
        WT_FLAG=(--branch "$BRANCH")
        [[ -n "$FROM_BRANCH" ]] && WT_FLAG+=(--from-branch "$FROM_BRANCH")
    else
        WT_FLAG=(--no-worktree)
    fi
    echo "=== aw-run iteration $ITER ==="
    set +e
    archon workflow run "$WF_NAME" "$EPIC" "${WT_FLAG[@]}"
    RC=$?
    set -e
    STATE="$(cat "$MARKER" 2>/dev/null || echo UNKNOWN)"
    echo "  iteration $ITER finished: rc=$RC state=$STATE"
    case "$STATE" in
        CONVERGED) RC=0; break ;;
        EXHAUSTED) RC=42; break ;;   # BLOCKED-ARBITRATION-EXHAUSTED
        ITERATE)   continue ;;
        *)         break ;;          # FAILED / UNKNOWN -> exit with archon's RC
    esac
done

if [[ "$RC" -eq 0 && "$CLEAN_WORKTREE" -eq 1 ]]; then
    echo "workflow converged after $ITER iteration(s) — cleaning worktree for $BRANCH"
    archon complete "$BRANCH" || echo "warning: 'archon complete' failed; clean up manually" >&2
elif [[ "$RC" -eq 42 ]]; then
    echo "BLOCKED-ARBITRATION-EXHAUSTED after $ITER iteration(s) — worktree $BRANCH preserved for human review" >&2
else
    echo "workflow failed (rc=$RC) after $ITER iteration(s) — worktree $BRANCH preserved" >&2
fi

exit "$RC"
