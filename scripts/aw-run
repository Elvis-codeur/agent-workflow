#!/usr/bin/env bash
# aw-run — render the aw-master-loop template with user-chosen models and
# invoke `archon workflow run` in an isolated worktree.
#
# Usage:
#   scripts/aw-run [options] <EPIC-ID>
#
# Options:
#   --coder    PROVIDER:MODEL           (default: claude:sonnet)
#   --tester   PROVIDER:MODEL           (default: codex:gpt-5-codex)
#   --master   PROVIDER:MODEL           (default: pi:kiro/minimax-m2-5)
#   --max-impl-iterations N             (default: 10)
#   --max-fix-attempts   N              (default: 3)
#   --branch BRANCH                     (default: archon/epic-<EPIC-ID>)
#   --dry-run                           render YAML and print path; do not run
#
# PROVIDER must be one of: pi, claude, codex.

set -euo pipefail

CODER="claude:sonnet"
TESTER="codex:gpt-5-codex"
MASTER="pi:kiro/minimax-m2-5"
MAX_IMPL=10
MAX_FIX=3
BRANCH=""
DRY=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --coder)              CODER="$2"; shift 2 ;;
        --tester)             TESTER="$2"; shift 2 ;;
        --master)             MASTER="$2"; shift 2 ;;
        --max-impl-iterations) MAX_IMPL="$2"; shift 2 ;;
        --max-fix-attempts)   MAX_FIX="$2"; shift 2 ;;
        --branch)             BRANCH="$2"; shift 2 ;;
        --dry-run)            DRY=1; shift ;;
        -h|--help)            sed -n '2,20p' "$0"; exit 0 ;;
        --) shift; break ;;
        -*) echo "unknown flag: $1" >&2; exit 2 ;;
        *)  EPIC="$1"; shift ;;
    esac
done

: "${EPIC:?EPIC-ID is required}"
BRANCH="${BRANCH:-archon/epic-${EPIC}}"

split() { IFS=':' read -r prov mdl <<<"$1"; echo "$prov" "$mdl"; }
read -r CODER_PROV  CODER_MDL  < <(split "$CODER")
read -r TESTER_PROV TESTER_MDL < <(split "$TESTER")
read -r MASTER_PROV MASTER_MDL < <(split "$MASTER")

REPO_ROOT="$(git rev-parse --show-toplevel)"
TEMPLATE="$REPO_ROOT/.archon/workflows/aw-master-loop.template.yaml"
RUNS_DIR="$REPO_ROOT/.archon/workflows/.runs"
mkdir -p "$RUNS_DIR"
RUN_ID="$(date -u +%Y%m%dT%H%M%SZ)-${EPIC//[^A-Za-z0-9]/_}"
OUT="$RUNS_DIR/aw-master-loop-$RUN_ID.yaml"

sed \
    -e "s|{{RUN_ID}}|$RUN_ID|g" \
    -e "s|{{MASTER_PROVIDER}}|$MASTER_PROV|g" \
    -e "s|{{MASTER_MODEL}}|$MASTER_MDL|g" \
    -e "s|{{CODER_PROVIDER}}|$CODER_PROV|g" \
    -e "s|{{CODER_MODEL}}|$CODER_MDL|g" \
    -e "s|{{TESTER_PROVIDER}}|$TESTER_PROV|g" \
    -e "s|{{TESTER_MODEL}}|$TESTER_MDL|g" \
    -e "s|{{MAX_IMPL_ITERATIONS}}|$MAX_IMPL|g" \
    -e "s|{{MAX_FIX_ATTEMPTS}}|$MAX_FIX|g" \
    "$TEMPLATE" > "$OUT"

echo "rendered → $OUT"
echo "  coder  = $CODER_PROV / $CODER_MDL"
echo "  tester = $TESTER_PROV / $TESTER_MDL"
echo "  master = $MASTER_PROV / $MASTER_MDL"
echo "  branch = $BRANCH"

if [[ "$DRY" -eq 1 ]]; then
    exit 0
fi

archon validate workflows "aw-master-loop-$RUN_ID"
exec archon workflow run "aw-master-loop-$RUN_ID" "$EPIC" --branch "$BRANCH"
