# Template — rendered by scripts/aw-run before each run.
# Placeholders ({{...}}) are substituted; everything else is real workflow YAML.
#
# Reference: https://github.com/coleam00/Archon — see .claude/docs/workflow-yaml-reference.md

name: aw-master-loop-{{RUN_ID}}
description: |
  Use when: User wants to drive a single epic from a progress.*.yaml file to
  `complete` status without supervising the coder/tester ping-pong.
  Triggers: "implement epic", "run epic", "aw master loop".
  Does: master agent reads the epic, dispatches the coder sub-agent (loop until
  review), then the tester sub-agent (write tests + run them). On test failure
  it loops the coder through /fix-blocked up to {{MAX_FIX_ATTEMPTS}} times.
  If the two sub-agents still disagree, the master arbitrates; if unsure it
  asks the human.
  NOT for: multi-epic planning (use /write-progress first), green-field
  scaffolding, or merging PRs.

# Master defaults — per-node overrides below take precedence.
provider: {{MASTER_PROVIDER}}
model: {{MASTER_MODEL}}

nodes:
  # ---------------------------------------------------------------- master
  - id: read-epic
    prompt: |
      Read the epic with id "$ARGUMENTS" from the project's progress.*.yaml
      files. Output strictly the following JSON:

        { "epic_id": "...", "scope": "frontend|backend|...",
          "implementation_paths": [...], "tests_paths": [...],
          "implementation_acceptance": "...", "tests_acceptance": "...",
          "spec_section": "..." }

      Do not edit any file.
    allowed_tools: ["Read", "Grep", "Glob"]
    output_format:
      type: object
      required: [epic_id, scope, implementation_paths, tests_paths]
      properties:
        epic_id: { type: string }
        scope: { type: string }
        implementation_paths: { type: array, items: { type: string } }
        tests_paths: { type: array, items: { type: string } }
        implementation_acceptance: { type: string }
        tests_acceptance: { type: string }
        spec_section: { type: string }

  # ---------------------------------------------------------------- coder
  # Single-shot: the /implement-epic skill instructs the agent to iterate
  # internally until the epic is review-ready or genuinely blocked. Macro-
  # level retries are handled by the outer aw-run recursion (see `decide`).
  #
  # Key steps are inlined here so the agent does NOT need to fetch SKILL.md
  # (saves ~1 000 tokens per run). CODEBASE-SUMMARY.md is read instead of
  # spending 5 000+ tokens on codebase exploration.
  - id: implement
    depends_on: [read-epic]
    provider: {{CODER_PROVIDER}}
    model: {{CODER_MODEL}}
    idle_timeout: 120000
    prompt: |
      You are the coder-agent for epic "$read-epic.output.epic_id".

      ## Step 0 — read context first (do this before anything else)
      Read in order — each takes one tool call:
      1. CODEBASE-SUMMARY.md           ← module layout, gate commands, test index
      2. docs/gotchas/INDEX.md          ← known bugs; skip gotchas whose scope doesn't overlap
      3. progress.$read-epic.output.scope.yaml   ← confirm epic status + acceptance criteria

      ## Your task
      Implement `$read-epic.output.implementation_paths`.
      Acceptance criteria (from the epic):
      $read-epic.output.implementation_acceptance
      Spec section: $read-epic.output.spec_section

      ## Rules
      - Implement ONLY the acceptance bullets. No extra features.
      - Do NOT write test files.
      - Run the gate commands listed in CODEBASE-SUMMARY.md before marking `review`.
      - Mark the epic `status: review` in the progress YAML when all gates pass.
      - Shell tip: append `|| true` to grep/find/ls existence checks.

      Iterate until the epic is `review` or you are genuinely blocked.

  # ---------------------------------------------------------------- tester (write)
  # Key steps inlined — saves the SKILL.md tool call (~1 000 tokens).
  - id: write-tests
    depends_on: [implement]
    provider: {{TESTER_PROVIDER}}
    model: {{TESTER_MODEL}}
    context: fresh
    idle_timeout: 120000
    prompt: |
      You are the tester-agent for epic "$read-epic.output.epic_id" (Mode A).

      ## Step 0 — read context first
      1. CODEBASE-SUMMARY.md           ← test file locations, test runner commands
      2. docs/gotchas/INDEX.md          ← known environment / toolchain bugs

      ## Your task
      Write the test files at: $read-epic.output.tests_paths
      Acceptance criteria for the tests:
      $read-epic.output.tests_acceptance

      ## Rules
      - Write tests that verify each acceptance bullet independently.
      - Do NOT run the tests.
      - Do NOT modify implementation files.
      - Do NOT update the progress YAML status.

  # ---------------------------------------------------------------- tester (run)
  - id: run-tests
    depends_on: [write-tests]
    bash: |
      bash scripts/aw-run-tests.sh $read-epic.output.scope \
                                    $read-epic.output.epic_id
    timeout: 600000

  # ---------------------------------------------------------------- coder fix (single-shot)
  # Key steps inlined — saves the SKILL.md tool call.
  - id: fix-blocked
    depends_on: [run-tests]
    when: "$run-tests.output != 'PASS'"
    provider: {{CODER_PROVIDER}}
    model: {{CODER_MODEL}}
    idle_timeout: 120000
    prompt: |
      You are the coder-agent. Epic "$read-epic.output.epic_id" has failing tests.

      ## Test failure output
      $run-tests.output

      ## Your task
      Fix ONLY implementation files at: $read-epic.output.implementation_paths
      You have up to {{MAX_FIX_ATTEMPTS}} attempts.
      After each fix, the test runner re-runs automatically.
      Stop when the epic is `review` again, or mark it `blocked` with a note
      if you exhaust your attempts.
      Shell tip: append `|| true` to grep/find/ls existence checks.

  - id: rerun-tests
    depends_on: [fix-blocked]
    when: "$run-tests.output != 'PASS'"
    bash: |
      bash scripts/aw-run-tests.sh $read-epic.output.scope \
                                    $read-epic.output.epic_id
    timeout: 600000

  # ---------------------------------------------------------------- master arbitration
  - id: arbitrate
    depends_on: [rerun-tests]
    when: "$rerun-tests.output != 'PASS'"
    # master provider/model inherited from top level
    idle_timeout: 120000
    prompt: |
      Run the /aw-master-loop skill on epic "$read-epic.output.epic_id".
      Coder and tester disagree after retries.

      Inputs already gathered for you:
      - epic: $read-epic.output
      - test output: $rerun-tests.output
      - run id: $WORKFLOW_ID
      - max arbitration attempts: $MAX_ARBITRATION_ATTEMPTS  (env)
      - counter file: .archon/state/arbitration-count-$read-epic.output.epic_id

      Follow the skill exactly: gather 7 inputs (including
      docs/gotchas/INDEX.md), classify into one of 8 buckets, check the
      counter, emit strict JSON. Do not edit any file other than the
      counter.
    allowed_tools: ["Read", "Grep", "Glob", "Bash"]
    output_format:
      type: object
      required: [verdict, rationale]
      properties:
        verdict:
          type: string
          enum: [coder_right, tester_right, unsure]
        rationale: { type: string }
        confidence: { type: number }
        bucket: { type: number }
        flags:
          type: object
          properties:
            spec_outdated: { type: boolean }
            scope_violation: { type: [string, "null"] }
            gotcha_id: { type: [string, "null"] }
            exhausted: { type: boolean }

  - id: ask-human
    depends_on: [arbitrate]
    when: "$arbitrate.output.verdict == 'unsure'"
    prompt: |
      The master agent could not decide. Present the situation to the human
      and ask them to pick `coder_right` or `tester_right`. Print the chosen
      verdict on the last line of your output.

  # ---------------------------------------------------------------- commit
  # >>> AUTOCOMMIT (stripped by scripts/aw-run when --no-autocommit)
  - id: commit
    depends_on: [run-tests, rerun-tests]
    trigger_rule: one_success
    when: "$run-tests.output == 'PASS' || $rerun-tests.output == 'PASS'"
    idle_timeout: 120000
    prompt: |
      Run the /commit skill. Do NOT push. Do NOT open a PR.
  # <<< AUTOCOMMIT

  # ---------------------------------------------------------------- update-context
  # Runs after a successful commit. Regenerates CODEBASE-SUMMARY.md's
  # AUTO-GENERATED section (zero AI tokens — pure bash/Python) and appends
  # a one-line entry to the "Recent epic changes" section so the next agent
  # starts with up-to-date context.
  # >>> AUTOCOMMIT (stripped by scripts/aw-run when --no-autocommit)
  - id: update-context
    depends_on: [commit]
    trigger_rule: one_success
    bash: |
      set -euo pipefail
      ROOT="$(git rev-parse --show-toplevel)"
      SUMMARY="$ROOT/CODEBASE-SUMMARY.md"

      # 1. Regenerate the AUTO-GENERATED section
      bash scripts/update-codebase-summary.sh

      # 2. Append an epic log entry to the AGENT-MAINTAINED section
      EPIC=$read-epic.output.epic_id
      SCOPE=$read-epic.output.scope
      TODAY="$(date -u +%Y-%m-%d)"
      PATHS=$read-epic.output.implementation_paths
      ENTRY="- ${EPIC} (${TODAY}): implemented ${PATHS} [scope: ${SCOPE}]"

      python3 - "$SUMMARY" "$ENTRY" <<'PY'
      import sys, pathlib, re
      f, entry = pathlib.Path(sys.argv[1]), sys.argv[2]
      txt = f.read_text()
      # Replace the placeholder line if this is the first entry
      txt = txt.replace(
          "*(no epics completed yet)*",
          entry
      )
      # Or append after the last entry in the section if entries exist
      if "*(no epics completed yet)*" not in txt and entry not in txt:
          txt = re.sub(
              r"(<!-- AGENT-MAINTAINED:END -->)",
              entry + "\n\n" + r"\1",
              txt
          )
      f.write_text(txt)
      PY

      # 3. Stage and amend the autocommit with the updated summary
      git add "$SUMMARY"
      git commit --amend --no-edit --no-verify 2>/dev/null || true
    timeout: 60000
  # <<< AUTOCOMMIT


  # Final node. Reads upstream outcomes and writes a one-word state to
  # .archon/state/iterate-decision-<epic> so scripts/aw-run can decide whether
  # to recurse, cleanup, or hard-fail. Always runs (trigger_rule: all_done).
  - id: decide
    depends_on: [run-tests, rerun-tests, arbitrate, ask-human, commit, update-context]
    trigger_rule: all_done
    bash: |
      # Do NOT double-quote these: Archon already single-quotes each substituted
      # value. Wrapping in "..." causes "'{json}" where the first '"' inside
      # the JSON prematurely closes the outer double-quote and breaks bash.
      bash scripts/aw-decide.sh \
        $read-epic.output.epic_id \
        $run-tests.output \
        $rerun-tests.output \
        done \
        $arbitrate.output \
        $ask-human.output
    timeout: 30000
